{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/security_check.py\"",
            "timeout": 5
          },
          {
            "type": "prompt",
            "prompt": "Analyze this tool call for security risks. Tool: $TOOL_NAME, Input: $TOOL_INPUT. Return JSON with 'safe' (boolean) and 'reason' (string). If safe, return {\"safe\": true}. If unsafe, return {\"safe\": false, \"reason\": \"description of the risk\"}.",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/post_write_check.py\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
